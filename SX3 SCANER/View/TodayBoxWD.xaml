<Window x:Class="SX3_SCANER.View.TodayBoxWD"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SX3_SCANER.View"
        mc:Ignorable="d"
        Title="Dữ liệu BOX hôm nay"

        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanResize"
        MinWidth="900"
        MinHeight="560"
        SizeToContent="Manual"
        Background="#F1F5F9"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Border Margin="12"
            Background="White"
            CornerRadius="16"
            Padding="14">

        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="3"
                              Opacity="0.18"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="📦"
                               FontSize="26"
                               VerticalAlignment="Center"/>

                    <TextBlock Text="DỮ LIỆU BOX HÔM NAY"
                               Margin="12,0,0,0"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#0F172A"
                               VerticalAlignment="Center"/>

                </StackPanel>

                <Border Grid.Column="1"
                        Padding="16,8"
                        CornerRadius="10"
                        Background="#DBEAFE">

                    <TextBlock Text="{Binding DataView.Count, StringFormat=Rows : {0}}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#F59E0B"/>

                </Border>
            </Grid>

            <!-- DATA GRID -->
            <DataGrid Grid.Row="2"
          ItemsSource="{Binding DataView}"
          AutoGenerateColumns="False"
          IsReadOnly="True"
          FontSize="13"
          RowHeight="34"
          ColumnHeaderHeight="38"
          GridLinesVisibility="Horizontal"
          HeadersVisibility="Column"
          CanUserAddRows="False"
          CanUserDeleteRows="False"
          CanUserResizeRows="False"
          CanUserResizeColumns="False"
          CanUserReorderColumns="False"
          CanUserSortColumns="False"
          BorderThickness="0"
          Background="White"
          ColumnWidth="*"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          HorizontalScrollBarVisibility="Auto"
          VerticalScrollBarVisibility="Auto"
          ScrollViewer.HorizontalScrollBarVisibility="Auto"
          ScrollViewer.VerticalScrollBarVisibility="Auto"
          ScrollViewer.CanContentScroll="True"
          LoadingRow="DataGrid_LoadingRow">

                <DataGrid.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="TextAlignment" Value="Center"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="TextWrapping" Value="NoWrap"/>
                    </Style>

                    <Style TargetType="CheckBox">
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                    <Style x:Key="CenterTextColumnStyle" TargetType="TextBlock">
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="TextAlignment" Value="Center"/>
                        <Setter Property="TextWrapping" Value="NoWrap"/>
                    </Style>

                    <Style x:Key="LeftTextColumnStyle" TargetType="TextBlock">
                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="TextAlignment" Value="Left"/>
                        <Setter Property="TextWrapping" Value="NoWrap"/>
                    </Style>

                    <Style x:Key="CenterCheckBoxStyle" TargetType="CheckBox">
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ScanTime"
                        Binding="{Binding ScanTime, StringFormat=dd/MM/yyyy HH:mm:ss}"
                        Width="1.3*"
                        ElementStyle="{StaticResource CenterTextColumnStyle}"/>

                    <DataGridTextColumn Header="BoxName"
                        Binding="{Binding BoxName}"
                        Width="1.1*"
                        ElementStyle="{StaticResource CenterTextColumnStyle}"/>

                    <DataGridTextColumn Header="ProductPartNumber"
                        Binding="{Binding ProductPartNumber}"
                        Width="1.2*"
                        ElementStyle="{StaticResource CenterTextColumnStyle}"/>

                    <DataGridTextColumn Header="ProductPartName"
                        Binding="{Binding ProductPartName}"
                        Width="1.2*"
                        ElementStyle="{StaticResource CenterTextColumnStyle}"/>

                    <DataGridTextColumn Header="SealNo"
                        Binding="{Binding SealNo}"
                        Width="0.8*"
                        ElementStyle="{StaticResource CenterTextColumnStyle}"/>

                    <DataGridTextColumn Header="LotNo"
                        Binding="{Binding LotNo}"
                        Width="0.7*"
                        ElementStyle="{StaticResource CenterTextColumnStyle}"/>

                    <DataGridTextColumn Header="ScanData"
                        Binding="{Binding ScanData}"
                        Width="1.8*"
                        ElementStyle="{StaticResource CenterTextColumnStyle}"/>

                    <DataGridCheckBoxColumn Header="ScanResult"
                            Binding="{Binding ScanResult, Mode=OneWay}"
                            Width="0.8*"
                            ElementStyle="{StaticResource CenterCheckBoxStyle}"/>

                    <DataGridTextColumn Header="ScanMessage"
                        Binding="{Binding ScanMessage}"
                        Width="1.5*"
                        ElementStyle="{StaticResource CenterTextColumnStyle}"/>

                    <DataGridTextColumn Header="ScanWorker"
                        Binding="{Binding ScanWorker}"
                        Width="0.8*"
                        ElementStyle="{StaticResource CenterTextColumnStyle}"/>

                    <DataGridTextColumn Header="ResultText"
                        Binding="{Binding ResultText}"
                        Width="0.8*"
                        ElementStyle="{StaticResource CenterTextColumnStyle}"/>

                    <DataGridTextColumn Header="Lo&#x1EA1;i th&#x00F9;ng"
                        Binding="{Binding BoxTypeText}"
                        Width="1.0*"
                        ElementStyle="{StaticResource CenterTextColumnStyle}"/>
                </DataGrid.Columns>

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8FAFC"/>
                        <Setter Property="Foreground" Value="#0F172A"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Padding" Value="6,0"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="6,0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="FontWeight" Value="Normal"/>
                        <Setter Property="Foreground" Value="#0F172A"/>

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ScanMessage}" Value="PASS">
                                <Setter Property="Background" Value="#DCFCE7"/>
                                <Setter Property="Foreground" Value="#166534"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding ResultText}" Value="PASS">
                                <Setter Property="Background" Value="#DCFCE7"/>
                                <Setter Property="Foreground" Value="#166534"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding IsPartialBox}" Value="True">
                                <Setter Property="Background" Value="#FEF3C7"/>
                                <Setter Property="Foreground" Value="#B45309"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding BoxType}" Value="PARTIAL">
                                <Setter Property="Background" Value="#FEF3C7"/>
                                <Setter Property="Foreground" Value="#B45309"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding ResultText}" Value="NG">
                                <Setter Property="Background" Value="#FEE2E2"/>
                                <Setter Property="Foreground" Value="#991B1B"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding ScanMessage}" Value="NG">
                                <Setter Property="Background" Value="#FEE2E2"/>
                                <Setter Property="Foreground" Value="#991B1B"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding ScanResult}" Value="False">
                                <Setter Property="Background" Value="#FEE2E2"/>
                                <Setter Property="Foreground" Value="#991B1B"/>
                            </DataTrigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E0F2FE"/>
                                <Setter Property="Foreground" Value="#0F172A"/>
                            </Trigger>

                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

            </DataGrid>

        </Grid>

    </Border>

</Window>
