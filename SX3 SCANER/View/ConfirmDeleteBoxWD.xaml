<Window x:Class="SX3_SCANER.View.ConfirmDeleteBoxWD"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="420"
        Height="220">

    <Border Background="White"
            CornerRadius="18"
            BorderBrush="#DC2626"
            BorderThickness="2"
            Padding="20">

        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="4"
                              Opacity="0.25"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="70" />
            </Grid.RowDefinitions>

            <!-- CONTENT -->
            <StackPanel VerticalAlignment="Center">

                <TextBlock Text="⚠ XÁC NHẬN HỦY THÙNG"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#DC2626"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Toàn bộ dữ liệu scan của thùng hiện tại sẽ bị xóa."
                           Margin="0,20,0,0"
                           FontSize="18"
                           TextAlignment="Center"
                           Foreground="#334155"/>

                <TextBlock Text="Bạn có chắc chắn muốn tiếp tục?"
                           Margin="0,10,0,0"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           Foreground="#0F172A"/>
            </StackPanel>

            <!-- BUTTON -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="❌ HỦY THÙNG"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="White"
                        Background="#DC2626"
                        BorderThickness="0"
                        Margin="0,8"
                        Click="BtnDelete_Click"/>

                <Button Grid.Column="2"
                        Content="↩ QUAY LẠI"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="White"
                        Background="#2563EB"
                        BorderThickness="0"
                        Margin="0,8"
                        Click="BtnCancel_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
