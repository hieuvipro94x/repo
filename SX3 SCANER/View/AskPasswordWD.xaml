<Window x:Class="SX3_SCANER.View.AskPasswordWD"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SX3_SCANER.View"
        mc:Ignorable="d"
         ResizeMode="NoResize" ShowInTaskbar="False" WindowStyle="None" WindowStartupLocation="CenterScreen"
        Title="AskPasswordWD" Height="50" Width="450">
	<Border BorderBrush="Blue" BorderThickness="1" CornerRadius="0">
		<Grid>
			<PasswordBox PasswordChar="*" x:Name="Passbox" KeyDown="Passbox_KeyDown" FontSize="44" Margin="3" TabIndex="0"/>
			<TextBlock Text="Password" Foreground="Gray" FontSize="18" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="4"/>
		</Grid>
	</Border>
</Window>
