                                                                                </Setter.Value>
                                                                            </Setter>

                                                                            <Style.Triggers>

                                                                                <DataTrigger Binding="{Binding InJob}" Value="True">

                                                                                    <DataTrigger.EnterActions>

                                                                                        <BeginStoryboard>

                                                                                            <Storyboard RepeatBehavior="Forever">

                                                                                                <DoubleAnimation
                                        Storyboard.TargetProperty="RenderTransform.ScaleX"
