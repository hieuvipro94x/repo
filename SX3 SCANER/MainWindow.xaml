<Window x:Class="SX3_SCANER.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SX3_SCANER"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:viewmodel="clr-namespace:SX3_SCANER.ViewModel"
        d:DataContext="{d:DesignInstance Type=viewmodel:MainViewModel}"
        Style="{StaticResource MaterialDesignWindow}"
        mc:Ignorable="d"
        Title="SX3 Scanner"
        Height="700"
        Width="1180"
        MinHeight="540"
        MinWidth="920"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanResize"
        SizeToContent="Manual"
        FontFamily="Segoe UI"
        Background="#F4F7FB"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F4F7FB" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1565C0" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#0D47A1" />
        <SolidColorBrush x:Key="TextMainBrush" Color="#263238" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#607D8B" />
        <SolidColorBrush x:Key="InputBgBrush" Color="#FAFBFD" />
        <SolidColorBrush x:Key="OkBrush" Color="#16A34A" />
        <SolidColorBrush x:Key="NgBrush" Color="#DC2626" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style TargetType="materialDesign:Card">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="UniformCornerRadius" Value="8" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Margin" Value="4" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="3" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Background" Value="{StaticResource InputBgBrush}" />
            <Setter Property="BorderBrush" Value="#D6DEE8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="3" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Background" Value="{StaticResource InputBgBrush}" />
            <Setter Property="BorderBrush" Value="#D6DEE8" />
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Margin" Value="3" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Background" Value="{StaticResource InputBgBrush}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryDarkBrush}" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E0E7EF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RowHeight" Value="28" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="AlternatingRowBackground" Value="#F7FAFC" />
            <Setter Property="HorizontalGridLinesBrush" Value="#E6EDF5" />
            <Setter Property="VerticalGridLinesBrush" Value="#E6EDF5" />
            <Setter Property="EnableRowVirtualization" Value="True" />
            <Setter Property="EnableColumnVirtualization" Value="True" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#EEF4FB" />
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="6,0" />
        </Style>

        <local:ScanRowBackgroundBrushConverter x:Key="ScanRowBackgroundBrushConverter"/>
        <local:ScanRowForegroundBrushConverter x:Key="ScanRowForegroundBrushConverter"/>

        <Style x:Key="UnifiedScanDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style x:Key="UnifiedScanRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="{Binding Converter={StaticResource ScanRowBackgroundBrushConverter}}"/>
            <Setter Property="Foreground" Value="{Binding Converter={StaticResource ScanRowForegroundBrushConverter}}"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0F2FE"/>
                    <Setter Property="Foreground" Value="#0F172A"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
            <Setter Property="Margin" Value="2" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,5" />
        </Style>


        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1565C0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style x:Key="SubFieldLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource FieldLabelStyle}">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#90A4AE" />
            <Setter Property="Margin" Value="12,0,0,0" />
        </Style>
        <Style x:Key="ExpectedValueBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFDE7" />
            <Setter Property="BorderBrush" Value="#F1E9A8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="MinHeight" Value="36" />
        </Style>
        <Style x:Key="ExpectedValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#0D47A1" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="ScanResultTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#16A34A" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#E3EAF2" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="10,3" />
        </Style>
        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="32" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
    </Window.Resources>
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="69*"/>
            <ColumnDefinition Width="571*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="White"
                BorderBrush="#E0E7EF"
                BorderThickness="0,0,0,1"
                Padding="6,2">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <TextBlock x:Name="txtUpdateStatus"
                           Text="Đang kiểm tra bản cập nhật..."
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />

                <Grid>
                    <Button x:Name="btnSoftwareUpdate"
                            Content="CẬP NHẬT PHẦN MỀM"
                            Click="SoftwareUpdate_Click"
                            IsEnabled="False" />

                    <Ellipse x:Name="updateNotificationDot"
                             Width="10"
                             Height="10"
                             Fill="#DC2626"
                             Stroke="White"
                             StrokeThickness="1"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Top"
                             Visibility="Collapsed" />
                </Grid>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" SelectedIndex="{Binding TabControlSelectedIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.ColumnSpan="2" Margin="2">
            <TabItem Header="QUÉT TEM">
                <Grid Margin="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.0*" MinWidth="290"/>
                        <ColumnDefinition Width="1.55*" MinWidth="340"/>
                        <ColumnDefinition Width="1.2*" MinWidth="320"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <materialDesign:Card Margin="4,3"
                                             UniformCornerRadius="8">
                            <Grid Margin="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- FORM NAME / DATE / QTY -->
                                <Grid Grid.Column="0"
          MinWidth="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="58" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Grid.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="TextAlignment" Value="Center" />
                                            <Setter Property="FontSize" Value="14" />
                                            <Setter Property="Foreground" Value="Gray" />
                                        </Style>
                                    </Grid.Resources>

                                    <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Text="Name" />

                                    <TextBlock Grid.Row="1"
                   Grid.Column="0"
                   Text="Date" />

                                    <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   Text="Qty" />

                                    <ComboBox Grid.Row="0"
                  Grid.Column="1"
                  MinWidth="0"
                  Height="30"
                  FontSize="13"
                  HorizontalAlignment="Stretch"
                  ItemsSource="{Binding PartNumberList}"
                  SelectedItem="{Binding SelectedPartNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  IsEnabled="{Binding CanSwitchProduct}" />

                                    <DatePicker Grid.Row="1"
                    Grid.Column="1"
                    MinWidth="0"
                    Height="30"
                    FontSize="13"
                    HorizontalAlignment="Stretch"
                    SelectedDate="{Binding SelectedDate}"
                    IsEnabled="{Binding CanSwitchProduct}" />

                                    <TextBox Grid.Row="2"
                 Grid.Column="1"
                 MinWidth="0"
                 Height="30"
                 FontSize="13"
                 HorizontalAlignment="Stretch"
                 Text="{Binding SelectedQuantity}"
                 IsEnabled="{Binding CanChangeProductInfo}" />
                                </Grid>

                                <!-- CỤM NÚT START / HỦY THÙNG -->
                                <Grid Grid.Column="1"
          Margin="5,0,0,0"
          VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                Width="50"
                Height="50"
                FontSize="13"
                FontWeight="Bold"
                Foreground="White"
                Command="{Binding STARTCMD}"
                CommandParameter="{Binding ElementName=TbxInputCode}"
                BorderThickness="3"
                BorderBrush="#2D2D2D"
                Content="{Binding BtnSTART_CONTENT}"
                Cursor="Hand">

                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border CornerRadius="100"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>

                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#43D14F"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding BtnSTART_CONTENT}" Value="STOP">
                                                        <Setter Property="Background" Value="#FF1E1E"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding BtnSTART_CONTENT}" Value="DỪNG">
                                                        <Setter Property="Background" Value="#FF1E1E"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Grid.Column="2"
                Width="50"
                Height="50"
                FontSize="11"
                FontWeight="Bold"
                Foreground="White"
                Background="#DC2626"
                BorderBrush="#7F1D1D"
                BorderThickness="3"
                Command="{Binding CancelBoxCMD}"
                Cursor="Hand">
                                        <TextBlock Text="HỦY&#x0a;THÙNG"
                       TextAlignment="Center"
                       Foreground="White"
                       FontWeight="Bold"/>

                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border CornerRadius="100"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>

                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasOpenScanSession}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <Button Grid.Column="4"
                Width="76"
                Height="50"
                FontSize="10"
                FontWeight="Bold"
                Foreground="White"
                Background="#F59E0B"
                BorderBrush="#B45309"
                BorderThickness="3"
                Command="{Binding ClosePartialBoxCMD}"
                Cursor="Hand">
                                        <TextBlock Text="&#x0110;&#x00D3;NG&#x0a;TH&#x00D9;NG L&#x1EBA;"
                       TextAlignment="Center"
                       Foreground="White"
                       FontWeight="Bold"/>

                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border CornerRadius="12"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>

                                    </Button>
                                </Grid>
                            </Grid>
                        </materialDesign:Card>
                        <materialDesign:Card Grid.Row="1"
                                             Margin="4"
                                             Padding="8"
                                             UniformCornerRadius="8">
                            <Grid>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- TIẾN ĐỘ -->
                                <Border Grid.Row="0"
            CornerRadius="8"
            Background="#EEF4FF"
            BorderBrush="#D9E6FA"
            BorderThickness="1"
            Padding="8,5">

                                    <DockPanel LastChildFill="True">

                                        <TextBlock Text="TIẾN ĐỘ SCAN"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#607D8B"
                       VerticalAlignment="Center"/>

                                        <TextBlock Text="{Binding CurrentScanProgress}"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#2563EB"
                       HorizontalAlignment="Right"/>

                                    </DockPanel>

                                </Border>

                                <!-- DANH SÁCH KIỂM TRA -->
                                <Grid Grid.Row="2">

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="5"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="5"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="5"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="5"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="64"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="42"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- HEADER -->
                                    <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Text="MỤC"
                   FontWeight="Bold"
                   Foreground="#64748B"/>

                                    <TextBlock Grid.Row="0"
                   Grid.Column="1"
                   Text="YÊU CẦU"
                   HorizontalAlignment="Center"
                   FontWeight="Bold"
                   Foreground="#64748B"/>

                                    <TextBlock Grid.Row="0"
                   Grid.Column="2"
                   Text="ĐÃ SCAN"
                   HorizontalAlignment="Center"
                   FontWeight="Bold"
                   Foreground="#64748B"/>

                                    <TextBlock Grid.Row="0"
                   Grid.Column="3"
                   Text="KQ"
                   HorizontalAlignment="Center"
                   FontWeight="Bold"
                   Foreground="#64748B"/>

                                    <!-- PNAME -->
                                    <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   Text="PName"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>

                                    <Border Grid.Row="2"
                Grid.Column="1"
                CornerRadius="8"
                Background="#FFF8E1"
                Padding="6,3"
                Margin="2">

                                        <TextBlock Text="{Binding PNameExpected}"
                       FontSize="13"
                       FontWeight="Bold"
                       TextTrimming="CharacterEllipsis"/>

                                    </Border>

                                    <TextBox Grid.Row="2"
                 Grid.Column="2"
                 Text="{Binding PNameScanResult}"
                 FontSize="13"
                 FontWeight="SemiBold"
                 Margin="2"
                 IsReadOnly="True"/>

                                    <Border Grid.Row="2"
                Grid.Column="3"
                CornerRadius="8"
                Margin="2">

                                        <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontWeight="Bold">

                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">

                                                    <Style.Triggers>

                                                        <DataTrigger Binding="{Binding PName_OK}" Value="1">
                                                            <Setter Property="Text" Value="OK"/>
                                                            <Setter Property="Foreground" Value="#16A34A"/>
                                                        </DataTrigger>

                                                        <DataTrigger Binding="{Binding PName_OK}" Value="0">
                                                            <Setter Property="Text" Value="NG"/>
                                                            <Setter Property="Foreground" Value="#DC2626"/>
                                                        </DataTrigger>

                                                    </Style.Triggers>

                                                </Style>
                                            </TextBlock.Style>

                                        </TextBlock>

                                    </Border>

                                    <!-- DATE -->
                                    <TextBlock Grid.Row="4"
                   Grid.Column="0"
                   Text="Date"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>

                                    <Border Grid.Row="4"
                Grid.Column="1"
                CornerRadius="8"
                Background="#FFF8E1"
                Padding="6,3"
                Margin="2">

                                        <TextBlock Text="{Binding SealNoExpected}"
                       FontSize="13"
                       FontWeight="Bold"/>

                                    </Border>

                                    <TextBox Grid.Row="4"
                 Grid.Column="2"
                 Text="{Binding SealnoScanResult}"
                 FontSize="13"
                 FontWeight="SemiBold"
                 Margin="2"
                 IsReadOnly="True"/>

                                    <TextBlock Grid.Row="4"
                   Grid.Column="3"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontWeight="Bold">

                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">

                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding SealNo_OK}" Value="1">
                                                        <Setter Property="Text" Value="OK"/>
                                                        <Setter Property="Foreground" Value="#16A34A"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding SealNo_OK}" Value="0">
                                                        <Setter Property="Text" Value="NG"/>
                                                        <Setter Property="Foreground" Value="#DC2626"/>
                                                    </DataTrigger>

                                                </Style.Triggers>

                                            </Style>
                                        </TextBlock.Style>

                                    </TextBlock>

                                    <!-- LOT -->
                                    <TextBlock Grid.Row="6"
                   Grid.Column="0"
                   Text="Lot"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>

                                    <Border Grid.Row="6"
                Grid.Column="1"
                CornerRadius="8"
                Background="#FFF8E1"
                Padding="6,3"
                Margin="2">

                                        <TextBlock Text="{Binding LotNoExpected}"
                       FontSize="13"
                       FontWeight="Bold"/>

                                    </Border>

                                    <TextBox Grid.Row="6"
                 Grid.Column="2"
                 Text="{Binding LotNoScanResult}"
                 FontSize="13"
                 FontWeight="SemiBold"
                 Margin="2"
                 IsReadOnly="True"/>

                                    <TextBlock Grid.Row="6"
                   Grid.Column="3"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontWeight="Bold">

                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">

                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding LotNo_OK}" Value="1">
                                                        <Setter Property="Text" Value="OK"/>
                                                        <Setter Property="Foreground" Value="#16A34A"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding LotNo_OK}" Value="0">
                                                        <Setter Property="Text" Value="NG"/>
                                                        <Setter Property="Foreground" Value="#DC2626"/>
                                                    </DataTrigger>

                                                </Style.Triggers>

                                            </Style>
                                        </TextBlock.Style>

                                    </TextBlock>

                                    <!-- SUFFIX -->
                                    <TextBlock Grid.Row="8"
                   Grid.Column="0"
                   Text="Suffix"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>

                                    <Border Grid.Row="8"
                Grid.Column="1"
                CornerRadius="8"
                Background="#FFF8E1"
                Padding="6,3"
                Margin="2">

                                        <TextBlock Text="{Binding SuffixExpected}"
                       FontSize="13"
                       FontWeight="Bold"/>

                                    </Border>

                                    <TextBox Grid.Row="8"
                 Grid.Column="2"
                 Text="{Binding SuffixScanResult}"
                 FontSize="13"
                 FontWeight="SemiBold"
                 Margin="2"
                 IsReadOnly="True"/>

                                    <TextBlock Grid.Row="8"
                   Grid.Column="3"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontWeight="Bold">

                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">

                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding Suffix_OK}" Value="1">
                                                        <Setter Property="Text" Value="OK"/>
                                                        <Setter Property="Foreground" Value="#16A34A"/>
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding Suffix_OK}" Value="0">
                                                        <Setter Property="Text" Value="NG"/>
                                                        <Setter Property="Foreground" Value="#DC2626"/>
                                                    </DataTrigger>

                                                </Style.Triggers>

                                            </Style>
                                        </TextBlock.Style>

                                    </TextBlock>

                                    <!-- LENGTH -->
                                    <Border Grid.Row="10"
                Grid.ColumnSpan="4"
                Background="#F8FAFC"
                CornerRadius="10"
                Padding="6"
                BorderBrush="#E2E8F0"
