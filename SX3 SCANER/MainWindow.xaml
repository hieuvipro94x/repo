                              Color="#00D9FF"
                              Opacity="1"/>
                                                                    </Ellipse.Effect>

                                                                </Ellipse>

                                                                <!-- RADAR -->
                                                                <Ellipse Stroke="#7DE3FF"
             StrokeThickness="2"
             Opacity="0.7">

                                                                    <Ellipse.Style>
                                                                        <Style TargetType="Ellipse">

                                                                            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>

