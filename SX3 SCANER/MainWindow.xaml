                                        To="1.35"
                                        Duration="0:0:1.1"/>

                                                                                                <DoubleAnimation
                                        Storyboard.TargetProperty="RenderTransform.ScaleY"
                                        From="1"
                                        To="1.35"
                                        Duration="0:0:1.1"/>

                                                                                                <DoubleAnimation
                                        Storyboard.TargetProperty="Opacity"
                                        From="0.8"
                                        To="0"
                                        Duration="0:0:1.1"/>

                                                                                            </Storyboard>

                                                                                        </BeginStoryboard>

                                                                                    </DataTrigger.EnterActions>

                                                                                </DataTrigger>

                                                                            </Style.Triggers>

                                                                        </Style>
                                                                    </Ellipse.Style>

                                                                </Ellipse>

