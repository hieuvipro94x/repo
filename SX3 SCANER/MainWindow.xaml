                                                                            <Setter Property="Visibility" Value="Collapsed"/>

                                                                            <Style.Triggers>

                                                                                <DataTrigger Binding="{Binding InJob}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>

                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Ellipse.Style>

