                            BorderThickness="1.5"
                            Background="{Binding OnlineAnnouncementBackground}"
                            BorderBrush="{Binding OnlineAnnouncementBorderBrush}">
                        <Border.Effect>
                            <DropShadowEffect Color="#334155"
                                              BlurRadius="14"
                                              ShadowDepth="2"
                                              Direction="270"
                                              Opacity="0.2" />
                        </Border.Effect>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOnlineAnnouncementVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding OnlineAnnouncementLevel}" Value="error" />
                                            <Condition Binding="{Binding IsOnlineAnnouncementVisible}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <MultiDataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="OnlineAnnouncementErrorPulse">
                                                <Storyboard RepeatBehavior="Forever"
                                                            AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1"
                                                                     To="0.82"
                                                                     Duration="0:0:0.8" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </MultiDataTrigger.EnterActions>
                                        <MultiDataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="OnlineAnnouncementErrorPulse" />
                                        </MultiDataTrigger.ExitActions>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Grid ClipToBounds="True"
                              VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="20" />
                                <RowDefinition Height="24" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.RowSpan="2"
                                       Text="{Binding OnlineAnnouncementIcon}"
                                       Foreground="{Binding OnlineAnnouncementForeground}"
                                       FontFamily="Segoe UI Emoji"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />

                            <TextBlock Grid.Column="1"
                                       Text="{Binding OnlineAnnouncementTitle}"
                                       Foreground="{Binding OnlineAnnouncementForeground}"
                                       FontSize="11"
                                       FontWeight="ExtraBold"
                                       VerticalAlignment="Center"
                                       Opacity="0.9" />

                            <Canvas Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="0,0,14,0"
                                    x:Name="onlineAnnouncementCanvas"
                                    ClipToBounds="True"
                                    SizeChanged="OnlineAnnouncement_SizeChanged">
                                <TextBlock x:Name="onlineAnnouncementText"
                                           Canvas.Top="2"
                                           Text="{Binding OnlineAnnouncementText, NotifyOnTargetUpdated=True}"
                                           Tag="{Binding OnlineAnnouncementAnimationVersion, NotifyOnTargetUpdated=True}"
                                           Foreground="{Binding OnlineAnnouncementForeground}"
                                           TargetUpdated="OnlineAnnouncement_TargetUpdated"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           SizeChanged="OnlineAnnouncement_SizeChanged">
                                    <TextBlock.RenderTransform>
                                        <TranslateTransform x:Name="onlineAnnouncementTransform" />
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Canvas>

                            <StackPanel Grid.Column="2"
                                        Grid.RowSpan="2"
                                        Margin="14,0,0,0"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Border Padding="9,4"
                                        CornerRadius="8"
                                        Background="#33FFFFFF"
                                        BorderBrush="#66FFFFFF"
                                        BorderThickness="1"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding IsAnnouncementCountdownVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Foreground="{Binding OnlineAnnouncementForeground}"
                                               FontFamily="Segoe UI Emoji"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Text="{Binding AnnouncementCountdownText}" />
                                </Border>

                                <Button Width="28"
                                        Height="28"
                                        MinHeight="0"
                                        Margin="8,0,0,0"
                                        Padding="0"
                                        Content="×"
                                        FontSize="18"
                                        FontWeight="Bold"
                                        Foreground="{Binding OnlineAnnouncementForeground}"
                                        Background="#22FFFFFF"
                                        BorderBrush="#55FFFFFF"
                                        BorderThickness="1"
                                        Click="OnlineAnnouncementClose_Click"
                                        Visibility="{Binding IsAnnouncementCloseVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>
        </Border>

    </Grid>
</Window>
