                                        Duration="0:0:0.8"/>

                                                                                            </Storyboard>

                                                                                        </BeginStoryboard>

                                                                                    </DataTrigger.EnterActions>

                                                                                </DataTrigger>

                                                                            </Style.Triggers>

                                                                        </Style>
                                                                    </Border.Style>

                                                                </Border>

                                                            </Grid>
                                                        </StackPanel>

                                                    </Grid>

                                                </Border>

