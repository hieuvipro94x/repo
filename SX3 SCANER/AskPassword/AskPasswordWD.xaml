<Window x:Class="SX3_SCANER.View.AskPasswordWD"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SX3_SCANER.View"
        mc:Ignorable="d"
        Title="Nhập mật khẩu"
        Height="170"
        Width="430"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True">

    <Border CornerRadius="16"
            Background="White"
            BorderBrush="#2563EB"
            BorderThickness="2"
            Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20"
                              ShadowDepth="4"
                              Opacity="0.25"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Nhập mật khẩu"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#1E293B"
                       HorizontalAlignment="Center"/>

            <Border Grid.Row="2"
                    Height="58"
                    CornerRadius="10"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    Background="#F8FAFC">

                <Grid>
                    <PasswordBox x:Name="Passbox"
                                 PasswordChar="*"
                                 KeyDown="Passbox_KeyDown"
                                 FontSize="30"
                                 Margin="12,0,80,0"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 TabIndex="0"/>

                    <TextBlock Text="Password"
                               Foreground="#94A3B8"
                               FontSize="16"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Margin="0,0,14,0"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>